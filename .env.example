# Supabase — shared DOME Platform project
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
ENVIRONMENT=development
# Comma-separated. In production: https://domelayer.com,https://analyzer.domelayer.com,https://llm-council.domelayer.com,https://data-intelligence.domelayer.com,https://document-intelligence.domelayer.com
ALLOWED_ORIGINS=http://localhost:3000
# Magic link callback URL. Auto-computed from ENVIRONMENT if unset.
# AUTH_CALLBACK_URL=https://domelayer.com/auth/callback

# Optional — Redis URL for cross-replica rate limiting. Falls back to in-process memory.
# REDIS_URL=redis://...
# RATELIMIT_PREFIX=

# Sentry — error tracking (optional in dev)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
